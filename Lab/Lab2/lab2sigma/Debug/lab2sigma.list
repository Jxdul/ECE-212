080003cc <TestAsmCall>:
.global cr
.syntax unified

.text
TestAsmCall:
PUSH {lr}
 80003cc:	b500      	push	{lr}
/*--------------------------------------*/

/*-------Students write their code here ------------*/
.equ Opcode, 0x20001000

PUSH {r4-r11}
 80003ce:	e92d 0ff0 	stmdb	sp!, {r4, r5, r6, r7, r8, r9, sl, fp}

/* Load opcode base and parameters */
ldr r4, =Opcode
 80003d2:	4c1d      	ldr	r4, [pc, #116]	@ (8000448 <part3_loop+0x1e>)
ldr r5, [r4, #4]       /* r5 = addr of first array (A) */
 80003d4:	6865      	ldr	r5, [r4, #4]
ldr r6, [r4, #8]       /* r6 = addr of second array (B) */
 80003d6:	68a6      	ldr	r6, [r4, #8]
ldr r9, [r4]           /* r9 = N (size) */
 80003d8:	f8d4 9000 	ldr.w	r9, [r4]

/* Part 1: Register Indirect With Offset */
ldr r7, [r4, #12]      /* r7 = dest1 */
 80003dc:	68e7      	ldr	r7, [r4, #12]
ldr r0, [r5]
 80003de:	6828      	ldr	r0, [r5, #0]
ldr r1, [r6]
 80003e0:	6831      	ldr	r1, [r6, #0]
add r2, r0, r1
 80003e2:	eb00 0201 	add.w	r2, r0, r1
str r2, [r7]
 80003e6:	603a      	str	r2, [r7, #0]
ldr r0, [r5, #4]
 80003e8:	6868      	ldr	r0, [r5, #4]
